# ================= Rihem environment variables =================
# Copy this file to ".env" and fill in real values. NEVER commit ".env".

# ---- Groq LLM (https://console.groq.com/keys) ----
GROQ_API_KEY=gsk_your_key_here
# Default model used by the AI recruitment module.
# Good options: llama-3.3-70b-versatile (quality) | llama-3.1-8b-instant (speed)
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Supabase ----
SUPABASE_URL=https://npouyrppjqbxifuvpqan.supabase.co
SUPABASE_KEY=your_supabase_service_key_here
